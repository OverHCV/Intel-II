\contentsline {figure}{\numberline {4.2}{\ignorespaces Evolución de Precision, Recall y F1-Score durante el entrenamiento de ResNet50. Las tres métricas convergen a valores superiores al 95\%.}}{23}{figure.caption.25}%
\contentsline {figure}{\numberline {4.3}{\ignorespaces Matriz de confusión de ResNet50 sobre el conjunto de prueba. Los valores en la diagonal representan clasificaciones correctas por familia de malware.}}{24}{figure.caption.26}%
\contentsline {figure}{\numberline {4.4}{\ignorespaces Curvas de entrenamiento del modelo baseline (Conventional CNN) para comparación.}}{24}{figure.caption.27}%
